    "item": [
        {
            "name": "1. Create Payment Order",
            "request": {
                "method": "POST",
                "header": [
                    { "key": "Content-Type", "value": "application/json" },
                    { "key": "Authorization", "value": "Bearer REPLACE_WITH_JWT" }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"checkoutId\": \"REPLACE_WITH_CHECKOUT_ID\"\n}"
                },
                "url": {
                    "raw": "http://localhost:8000/api/v1/payments/create-order",
                    "protocol": "http",
                    "host": ["localhost"],
                    "port": "8000",
                    "path": ["api", "v1", "payments", "create-order"]
                }
            }
        },
        {
            "name": "2. Verify Payment (Success simulation)",
            "request": {
                "method": "POST",
                "header": [
                    { "key": "Content-Type", "value": "application/json" },
                    { "key": "Authorization", "value": "Bearer REPLACE_WITH_JWT" }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"razorpayOrderId\": \"REPLACE_WITH_ORDER_ID\",\n    \"razorpayPaymentId\": \"pay_mock_payment_id\",\n    \"razorpaySignature\": \"mock_signature_for_testing\"\n}"
                },
                "url": {
                    "raw": "http://localhost:8000/api/v1/payments/verify",
                    "protocol": "http",
                    "host": ["localhost"],
                    "port": "8000",
                    "path": ["api", "v1", "payments", "verify"]
                }
            }
        },
        {
            "name": "3. Verify Payment (Invalid Signature - Fail)",
            "request": {
                "method": "POST",
                "header": [
                    { "key": "Content-Type", "value": "application/json" },
                    { "key": "Authorization", "value": "Bearer REPLACE_WITH_JWT" }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"razorpayOrderId\": \"REPLACE_WITH_ORDER_ID\",\n    \"razorpayPaymentId\": \"pay_mock_payment_id\",\n    \"razorpaySignature\": \"INVALID_SIGNATURE_xyz\"\n}"
                },
                "url": {
                    "raw": "http://localhost:8000/api/v1/payments/verify",
                    "protocol": "http",
                    "host": ["localhost"],
                    "port": "8000",
                    "path": ["api", "v1", "payments", "verify"]
                }
            }
        },
        {
            "name": "4. Mark Payment as Failed",
            "request": {
                "method": "POST",
                "header": [
                    { "key": "Content-Type", "value": "application/json" },
                    { "key": "Authorization", "value": "Bearer REPLACE_WITH_JWT" }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"razorpayOrderId\": \"REPLACE_WITH_ORDER_ID\",\n    \"reason\": \"User cancelled payment popup\"\n}"
                },
                "url": {
                    "raw": "http://localhost:8000/api/v1/payments/failed",
                    "protocol": "http",
                    "host": ["localhost"],
                    "port": "8000",
                    "path": ["api", "v1", "payments", "failed"]
                }
            }
        },
        {
            "name": "5. Get Payment History",
            "request": {
                "method": "GET",
                "header": [
                    { "key": "Authorization", "value": "Bearer REPLACE_WITH_JWT" }
                ],
                "url": {
                    "raw": "http://localhost:8000/api/v1/payments/history",
                    "protocol": "http",
